<svg width="1400" height="700" viewBox="0 0 1400 700" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1400" y2="700" gradientUnits="userSpaceOnUse">
      <stop stop-color="#0F172A"/>
      <stop offset="1" stop-color="#1E3A8A"/>
    </linearGradient>

    <linearGradient id="cityGlow" x1="0" y1="0" x2="1" y2="1">
      <stop stop-color="#38BDF8"/>
      <stop offset="1" stop-color="#22C55E"/>
    </linearGradient>

    <filter id="softGlow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="8" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>

  <rect width="1400" height="700" fill="url(#bg)"/>

  <!-- Grid -->
  <g opacity="0.12">
    <path d="M0 100H1400" stroke="white"/>
    <path d="M0 200H1400" stroke="white"/>
    <path d="M0 300H1400" stroke="white"/>
    <path d="M0 400H1400" stroke="white"/>
    <path d="M0 500H1400" stroke="white"/>
    <path d="M0 600H1400" stroke="white"/>

    <path d="M100 0V700" stroke="white"/>
    <path d="M300 0V700" stroke="white"/>
    <path d="M500 0V700" stroke="white"/>
    <path d="M700 0V700" stroke="white"/>
    <path d="M900 0V700" stroke="white"/>
    <path d="M1100 0V700" stroke="white"/>
    <path d="M1300 0V700" stroke="white"/>
  </g>

  <!-- Connected city skyline -->
  <g opacity="0.95">
    <rect x="120" y="390" width="90" height="190" rx="4" fill="#334155"/>
    <rect x="240" y="310" width="110" height="270" rx="4" fill="#475569"/>
    <rect x="390" y="240" width="120" height="340" rx="4" fill="#64748B"/>
    <rect x="550" y="360" width="100" height="220" rx="4" fill="#334155"/>
    <rect x="700" y="280" width="140" height="300" rx="4" fill="#475569"/>
    <rect x="890" y="220" width="120" height="360" rx="4" fill="#64748B"/>
    <rect x="1050" y="330" width="140" height="250" rx="4" fill="#334155"/>
  </g>

  <!-- Smart nodes -->
  <g filter="url(#softGlow)">
    <circle cx="300" cy="220" r="10" fill="#38BDF8"/>
    <circle cx="520" cy="180" r="10" fill="#22C55E"/>
    <circle cx="760" cy="170" r="10" fill="#38BDF8"/>
    <circle cx="980" cy="160" r="10" fill="#22C55E"/>

    <path d="M300 220C380 120 450 120 520 180" stroke="url(#cityGlow)" stroke-width="4"/>
    <path d="M520 180C600 120 690 120 760 170" stroke="url(#cityGlow)" stroke-width="4"/>
    <path d="M760 170C840 110 920 110 980 160" stroke="url(#cityGlow)" stroke-width="4"/>
  </g>

  <!-- Digital twin / interoperability rings -->
  <g opacity="0.85">
    <circle cx="1120" cy="170" r="80" stroke="#38BDF8" stroke-width="2"/>
    <circle cx="1120" cy="170" r="55" stroke="#22C55E" stroke-width="2"/>
    <circle cx="1120" cy="170" r="30" stroke="#FFFFFF" stroke-width="2"/>
  </g>

  <!-- Main text -->
  <text x="120" y="120" fill="white" font-family="Arial, Helvetica, sans-serif" font-size="28" letter-spacing="3">
    OPEN MOBILE ALLIANCE
  </text>

  <text x="120" y="210" fill="white" font-family="Arial, Helvetica, sans-serif" font-size="54" font-weight="700">
    Smart Cities SIG Collaboration
  </text>

  <text x="120" y="275" fill="#CBD5E1" font-family="Arial, Helvetica, sans-serif" font-size="28">
    Interoperability initiative led by Madrid Digital
  </text>

  <text x="120" y="325" fill="#CBD5E1" font-family="Arial, Helvetica, sans-serif" font-size="28">
    Connecting municipalities, standards and digital ecosystems
  </text>

  <!-- Bottom information strip -->
  <rect x="0" y="620" width="1400" height="80" fill="#020617" opacity="0.92"/>

  <text x="120" y="670" fill="#E2E8F0" font-family="Arial, Helvetica, sans-serif" font-size="24">
    Smart City Expo World Congress • Barcelona • November 3–5, 2026
  </text>
</svg>
